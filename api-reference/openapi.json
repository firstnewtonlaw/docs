{
  "openapi": "3.1.0",
  "info": {
    "title": "Inject.Today API",
    "description": "API for retrieving and updating version and exploit data for Inject.Today.",
    "version": "1.0.0",
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://inject.today"
    }
  ],
  "paths": {
    "/api/versions/current": {
      "get": {
        "summary": "Current",
        "description": "Returns the current versions of Roblox.",
        "responses": {
          "200": {
            "description": "Current Roblox versions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionsResponse"
                },
                "example": {
                  "Windows": {
                    "Version": "version-bef193a8f3d14d3c",
                    "Date": "3/17/2025 4:04:55 PM"
                  },
                  "Macintosh": {
                    "Version": "version-0b638b32e4ac485c",
                    "Date": "3/17/2025 4:04:32 PM"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/versions/future": {
      "get": {
        "summary": "Future",
        "description": "Returns the future versions of Roblox.",
        "responses": {
          "200": {
            "description": "Future Roblox versions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionsResponse"
                },
                "example": {
                  "Windows": {
                    "Version": "version-xyz456789",
                    "Date": "3/20/2025 10:14:55 AM"
                  },
                  "Macintosh": {
                    "Version": "version-123abc789xyz",
                    "Date": "3/20/2025 10:14:32 AM"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/versions/previous": {
      "get": {
        "summary": "Previous",
        "description": "Returns the previous versions of Roblox.",
        "responses": {
          "200": {
            "description": "Previous Roblox versions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionsResponse"
                },
                "example": {
                  "Windows": {
                    "Version": "version-689e359b09ad43b0",
                    "Date": "2026-04-09T00:52:39.162Z"
                  },
                  "Macintosh": {
                    "Version": "version-08d2b9589bf14135",
                    "Date": "2026-04-09T00:40:09.943Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/cheats": {
      "get": {
        "summary": "Cheats",
        "description": "Returns detailed data for all cheats available on Inject.Today, including platform information, pricing, detection status, and reviews.",
        "responses": {
          "200": {
            "description": "List of cheats with detailed information.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "patternProperties": {
                    "^[A-Za-z0-9_-]+$": {
                      "$ref": "#/components/schemas/Cheat"
                    }
                  },
                  "additionalProperties": false
                },
                "example": {
                  "Severe": {
                    "Identifier": "xJaK2vrMde",
                    "Tags": {
                      "Windows": {
                        "Rank": "Reputable",
                        "Parent": "Cheats"
                      }
                    },
                    "Attributes": {
                      "Windows": {
                        "Score": 95,
                        "Resellers": false,
                        "Type": "External",
                        "Access": "Usermode",
                        "PricingModel": ["Lifetime"],
                        "ReleaseDate": "06/2021"
                      }
                    },
                    "Cost": {
                      "Windows": "$20 Lifetime"
                    },
                    "Visibility": {
                      "Windows": {
                        "Website": true,
                        "Updates": true,
                        "Reviews": true,
                        "Settings": true
                      }
                    },
                    "Links": {
                      "Windows": {
                        "Discord": "https://discord.com/invite/severe1",
                        "Purchase": "https://discord.com/invite/severe1"
                      }
                    },
                    "Platforms": {
                      "Windows": {
                        "Detection": {
                          "Raw": 0,
                          "Readable": "Fully undetected"
                        },
                        "Tracked": true,
                        "Versions": {
                          "Software": "None",
                          "Roblox": "None"
                        }
                      }
                    },
                    "Name": "Severe",
                    "Update": {
                      "Platforms": {
                        "Windows": {
                          "Timestamp": "2025-10-10T21:20:11.580Z"
                        }
                      }
                    },
                    "Reviews": [
                      {
                        "Identifier": "3D70S2",
                        "Author": "1237865177605738546",
                        "Rating": 5,
                        "Comment": "Severe has always been my number 1 external for ages...",
                        "Timestamp": 1760131972308,
                        "Parent": "Severe"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/cheats/reviews": {
      "get": {
        "summary": "Cheat Reviews",
        "description": "Returns reviews for all cheats available on Inject.Today.",
        "responses": {
          "200": {
            "description": "Map of cheat names to their review collections.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "patternProperties": {
                    "^[A-Za-z0-9_-]+$": {
                      "$ref": "#/components/schemas/CheatReviews"
                    }
                  }
                },
                "example": {
                  "Blueberry": {
                    "Identifier": "UdfCYb5qPZ",
                    "Reviews": [
                      {
                        "Author": "1lpbjhtqcq",
                        "Parent": "Blueberry",
                        "Rating": 3,
                        "Comment": "bsod on hop for me",
                        "Summary": "Bad",
                        "Platform": "Windows",
                        "Timestamp": 1773363151668,
                        "Categories": [
                          {
                            "Rating": 3,
                            "Comment": "bsod on hop for me",
                            "Summary": "Bad",
                            "Category": "Overall"
                          }
                        ],
                        "Identifier": "3L3L1T"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/cheats/reviews/{idOrName}": {
      "get": {
        "summary": "Cheat Reviews by ID or Name",
        "description": "Returns reviews for a specific cheat by ID or name.",
        "parameters": [
          {
            "name": "idOrName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The cheat identifier or name."
          }
        ],
        "responses": {
          "200": {
            "description": "Review collection for the specified cheat.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheatReviews"
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/cheats/updates": {
      "get": {
        "summary": "Cheat Updates",
        "description": "Returns update information for all cheats available on Inject.Today.",
        "responses": {
          "200": {
            "description": "Map of cheat names to their update history.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "patternProperties": {
                    "^[A-Za-z0-9_-]+$": {
                      "$ref": "#/components/schemas/CheatUpdates"
                    }
                  }
                },
                "example": {
                  "Blueberry": {
                    "Identifier": "UdfCYb5qPZ",
                    "Update": {
                      "Metadata": [],
                      "Platforms": {
                        "Windows": {
                          "Timestamp": "2026-01-26T18:02:03.338Z"
                        }
                      }
                    }
                  },
                  "Bunni": {
                    "Identifier": "hTiLNnYKiU",
                    "Update": {
                      "Metadata": [
                        {
                          "Platform": "Windows",
                          "Versions": {
                            "Roblox": "version-d34359a5577645e2",
                            "Software": "2.3.6"
                          },
                          "Changelog": "[*] sUNC 98%\n[*] Rewrote way to much\n[*] UPDATED FOR version-d34359a5577645e2"
                        }
                      ],
                      "Platforms": {
                        "Windows": {
                          "Timestamp": "2026-02-10T14:30:00.000Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/cheats/updates/{idOrName}": {
      "get": {
        "summary": "Cheat Updates by ID or Name",
        "description": "Returns update information for a specific cheat by ID or name.",
        "parameters": [
          {
            "name": "idOrName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The cheat identifier or name."
          }
        ],
        "responses": {
          "200": {
            "description": "Update information for the specified cheat.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheatUpdates"
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/update": {
      "post": {
        "summary": "Update Versions",
        "description": "Updates version information for Roblox and Inject.Today software. Requires authorization.",
        "security": [
          {
            "cheatAuth": []
          }
        ],
        "requestBody": {
          "description": "Version update payload.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRequest"
              },
              "example": {
                "Versions": {
                  "Roblox": "version-abcdef123456",
                  "Software": "v2.4.1",
                  "Changelog": "Fixed compatibility issues and improved stability."
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Version update successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "success": true,
                    "message": "Version data updated successfully."
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid Authorization header.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PlatformVersion": {
        "type": "object",
        "properties": {
          "Version": {
            "type": "string",
            "description": "Version identifier."
          },
          "Date": {
            "type": "string",
            "description": "Date/time when this version was recorded."
          }
        },
        "required": ["Version", "Date"]
      },
      "VersionsResponse": {
        "type": "object",
        "properties": {
          "Windows": {
            "$ref": "#/components/schemas/PlatformVersion"
          },
          "Macintosh": {
            "$ref": "#/components/schemas/PlatformVersion"
          }
        }
      },
      "ReviewCategory": {
        "type": "object",
        "properties": {
          "Category": {
            "type": "string",
            "description": "The category being reviewed (e.g. Combat, Visuals, Overall)."
          },
          "Rating": {
            "type": "number",
            "description": "Rating for this category (1-5).",
            "minimum": 1,
            "maximum": 5
          },
          "Comment": {
            "type": "string",
            "description": "Comment for this category."
          },
          "Summary": {
            "type": "string",
            "description": "Short verdict label.",
            "enum": ["Bad", "Decent", "Good"]
          },
          "Media": {
            "type": "string",
            "description": "Optional media filename attached to this category review."
          }
        },
        "required": ["Category", "Rating", "Comment"]
      },
      "Review": {
        "type": "object",
        "properties": {
          "Identifier": {
            "type": "string",
            "description": "Unique review identifier."
          },
          "Author": {
            "type": "string",
            "description": "User ID of the review author."
          },
          "Parent": {
            "type": "string",
            "description": "The cheat name this review belongs to."
          },
          "Platform": {
            "type": "string",
            "description": "Platform the review was submitted for.",
            "enum": ["Windows", "Macintosh"]
          },
          "Rating": {
            "type": "number",
            "description": "Overall rating (1-5).",
            "minimum": 1,
            "maximum": 5
          },
          "Comment": {
            "type": "string",
            "description": "Overall review comment."
          },
          "Summary": {
            "type": "string",
            "description": "Short overall verdict.",
            "enum": ["Bad", "Decent", "Good"]
          },
          "Timestamp": {
            "type": "integer",
            "description": "Unix timestamp in milliseconds of when the review was posted."
          },
          "Categories": {
            "type": "array",
            "description": "Per-category breakdown of the review.",
            "items": {
              "$ref": "#/components/schemas/ReviewCategory"
            }
          },
          "Media": {
            "type": "string",
            "description": "Optional media filename attached to the overall review."
          }
        },
        "required": ["Identifier", "Author", "Parent", "Platform", "Rating", "Comment", "Timestamp", "Categories"]
      },
      "CheatReviews": {
        "type": "object",
        "properties": {
          "Identifier": {
            "type": "string",
            "description": "Unique cheat identifier."
          },
          "Reviews": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Review"
            }
          }
        },
        "required": ["Identifier", "Reviews"]
      },
      "UpdateMetadataEntry": {
        "type": "object",
        "properties": {
          "Platform": {
            "type": "string",
            "description": "Platform this update applies to.",
            "enum": ["Windows", "Macintosh"]
          },
          "Versions": {
            "type": "object",
            "properties": {
              "Roblox": {
                "type": "string",
                "description": "Roblox version this update targets."
              },
              "Software": {
                "type": "string",
                "description": "Software version released."
              }
            },
            "required": ["Roblox", "Software"]
          },
          "Changelog": {
            "type": "string",
            "description": "Changelog text for this update."
          }
        },
        "required": ["Platform", "Versions"]
      },
      "UpdatePlatformTimestamp": {
        "type": "object",
        "properties": {
          "Timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the last update on this platform."
          }
        },
        "required": ["Timestamp"]
      },
      "CheatUpdates": {
        "type": "object",
        "properties": {
          "Identifier": {
            "type": "string",
            "description": "Unique cheat identifier."
          },
          "Update": {
            "type": "object",
            "properties": {
              "Metadata": {
                "type": "array",
                "description": "List of historical update entries.",
                "items": {
                  "$ref": "#/components/schemas/UpdateMetadataEntry"
                }
              },
              "Platforms": {
                "type": "object",
                "description": "Latest update timestamp per platform.",
                "additionalProperties": {
                  "$ref": "#/components/schemas/UpdatePlatformTimestamp"
                }
              }
            },
            "required": ["Metadata", "Platforms"]
          }
        },
        "required": ["Identifier", "Update"]
      },
      "UpdateRequest": {
        "type": "object",
        "properties": {
          "Versions": {
            "type": "object",
            "properties": {
              "Roblox": {
                "type": "string"
              },
              "Software": {
                "type": "string"
              },
              "Changelog": {
                "type": "string"
              }
            },
            "required": ["Roblox", "Software"]
          }
        },
        "required": ["Versions"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["error", "message"]
      },
      "Cheat": {
        "type": "object",
        "properties": {
          "Identifier": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Tags": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "Rank": { "type": "string" },
                "Parent": { "type": "string" }
              }
            }
          },
          "Attributes": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "Score": { "type": "integer" },
                "Resellers": { "type": "boolean" },
                "Type": { "type": "string" },
                "Access": { "type": "string" },
                "PricingModel": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "ReleaseDate": { "type": "string" }
              }
            }
          },
          "Cost": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "Visibility": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "Website": { "type": "boolean" },
                "Updates": { "type": "boolean" },
                "Reviews": { "type": "boolean" },
                "Settings": { "type": "boolean" }
              }
            }
          },
          "Links": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "Website": { "type": "string" },
                "Discord": { "type": "string" },
                "Purchase": { "type": "string" }
              }
            }
          },
          "Platforms": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "Detection": {
                  "type": "object",
                  "properties": {
                    "Raw": { "type": "integer" },
                    "Readable": { "type": "string" }
                  }
                },
                "Tracked": { "type": "boolean" },
                "Versions": {
                  "type": "object",
                  "properties": {
                    "Software": { "type": "string" },
                    "Roblox": { "type": "string" }
                  }
                }
              }
            }
          },
          "Update": {
            "$ref": "#/components/schemas/CheatUpdates"
          },
          "Reviews": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Review"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "cheatAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Cheat authentication header of the form `Cheat <token>`, where `<token>` is your auth token."
      }
    }
  }
}
